rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        request.auth.token.role in ['Admin', 'Super-Admin'];
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.role == 'Super-Admin';
    }

    // ── Messages ─────────────────────────────────────────────────
    // Any authenticated user can read/write community & admin chat.
    // Private messages are restricted to participants.
    match /messages/{messageId} {
      allow read: if isSignedIn() && (
        resource.data.chatType == 'community' ||
        resource.data.chatType == 'admin' ||
        request.auth.uid in resource.data.participants
      );
      allow create: if isSignedIn() && (
        request.resource.data.chatType == 'community' ||
        request.resource.data.chatType == 'admin' ||
        request.auth.uid in request.resource.data.participants
      );
      // Allow reaction + read-receipt updates by any participant/sender
      allow update: if isSignedIn() && (
        resource.data.authorId == request.auth.uid ||
        resource.data.chatType == 'community' ||
        resource.data.chatType == 'admin' ||
        request.auth.uid in resource.data.participants
      );
      allow delete: if isAdmin();
    }

    // ── Users ─────────────────────────────────────────────────────
    // Authenticated users can read their own doc; admins can read all.
    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId || isAdmin()
      );
      allow write: if isSuperAdmin();
    }

    // ── Public read collections ───────────────────────────────────
    match /events/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testimonies/{docId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /prayer_requests/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /teachings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /blog_posts/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /leaders/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /campuses/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ministries/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /serve_teams/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Default: deny everything else ────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
